    "def decimael_binario(numero)\n",
    "    s = Stack()\n",
    "    wilhe numero > 0 \n",
    "        resto = numero % 2\n",
    "        s.psch(resto)\n",
    "        numero = numero // 2 \n",
    "    binario = ''\n",
    "    while not is_empty():\n",
    "        binario = binario + str(s.pop))\n",
    "    return binario \n"
